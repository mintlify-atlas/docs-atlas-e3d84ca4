  "keyFeatures": [
    "Component-based UI model with SSR and CSR rendering modes",
    "Annotation-driven reactive state management (@State, @Bind, @Call)",
    "WebSocket-powered live DOM patching via idiomorph morphing",
    "Built-in client-side router with @Route and @Param annotations",
    "APT (Annotation Processing) for zero-overhead AOT compilation",
    "Stateless mode: cryptographically-signed state sent to client (zero server memory)",
    "Redis-backed distributed session state via jreactive-store-redis",
    "Scoped CSS and co-located JS per component",
    "Spring Boot auto-configuration via jreactive-starter-spring",
    "Pre-built UI component library (JButton, JInput, JForm, JTable, JModal, etc.)"
  ],
  "publicApiSurface": [
    "HtmlComponent (base class for all components)",
    "ReactiveVar<T> (reactive value holder)",
    "Type<T> (typed reactive wrapper)",
    "@State (marks field as reactive state)",
    "@Bind (exposes field as template binding)",
    "@Call (marks method as callable from template events)",
    "@Route (maps component to a URL path)",
    "@Param (injects route path parameters)",
    "@UrlParam (injects URL query parameters)",
    "@Stateful (enables Redis/DB serialization of component state)",
    "@Stateless (zero-memory mode with signed client state)",
    "@Client (enables client-side rendering shell)",
    "@DomMode (controls SERVER_OWNED HTML-on-the-wire mode)",
    "EventBus (pub/sub bus for cross-component communication)",
    "SmartList<T> / SmartMap<K,V> / SmartSet<T> (reactive collections)",
    "StateStore (SPI for pluggable session state backends)",
    "AstComponentEngine.installAsDefault() (bootstrap entry point)",
    "ComponentEngine.setStrategy(Strategy) (custom engine injection)"
  ]
}
